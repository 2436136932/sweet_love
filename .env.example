# MySQL 数据库连接地址。
DATABASE_URL="mysql://root:123456@localhost:3306/sweet_love"

# JWT 登录令牌签名密钥。
JWT_SECRET="replace-with-a-long-random-secret"

# 文件存储方式，可选 local 或 s3。
STORAGE_DRIVER="local"

# 本地上传目录，local 存储时使用。
UPLOAD_DIR="uploads"

# 单个上传文件最大体积，单位 MB。
MAX_UPLOAD_MB="5"

# S3 兼容存储区域。
S3_REGION=""

# S3 兼容存储 bucket 名称。
S3_BUCKET=""

# S3 兼容存储 Access Key ID。
S3_ACCESS_KEY_ID=""

# S3 兼容存储 Secret Access Key。
S3_SECRET_ACCESS_KEY=""

# S3 兼容存储 endpoint，标准 AWS S3 可留空。
S3_ENDPOINT=""

# S3 文件公开访问地址或 CDN 地址。
S3_PUBLIC_URL=""

# 是否使用 S3 path-style 访问。
S3_FORCE_PATH_STYLE="false"

# 高德地图 Web JS API Key。
VITE_AMAP_KEY=""

# 高德地图安全密钥。
VITE_AMAP_SECURITY_CODE=""

# 当前启用的 AI provider，可选 openai-compatible、gemini、claude。
AI_PROVIDER="openai-compatible"

# OpenAI-compatible API Key。
OPENAI_COMPATIBLE_API_KEY=""

# OpenAI-compatible API 基地址。
OPENAI_COMPATIBLE_BASE_URL=""

# OpenAI-compatible 模型名。
OPENAI_COMPATIBLE_MODEL=""

# OpenAI-compatible 请求超时时间，单位毫秒。
OPENAI_COMPATIBLE_TIMEOUT_MS="60000"

# OpenAI-compatible 单次最大输出 token 数。
OPENAI_COMPATIBLE_MAX_TOKENS="2048"

# OpenAI-compatible 生成温度。
OPENAI_COMPATIBLE_TEMPERATURE="0.7"

# Gemini API Key。
GEMINI_API_KEY=""

# Gemini 模型名。
GEMINI_MODEL="gemini-3.5-flash"

# Gemini 请求超时时间，单位毫秒。
GEMINI_TIMEOUT_MS="60000"

# Gemini 单次最大输出 token 数。
GEMINI_MAX_TOKENS="2048"

# Gemini 生成温度。
GEMINI_TEMPERATURE="0.7"

# Claude API Key。
CLAUDE_API_KEY=""

# Claude 模型名。
CLAUDE_MODEL="claude-opus-4-8"

# Claude 请求超时时间，单位毫秒。
CLAUDE_TIMEOUT_MS="60000"

# Claude 单次最大输出 token 数。
CLAUDE_MAX_TOKENS="2048"

# Pexels 图片 API Key，用于 AI 菜谱配图。
PEXELS_API_KEY=""

# Pixabay 图片 API Key，用于 AI 菜谱配图。
PIXABAY_API_KEY=""

# 应用外部访问地址。
APP_URL=""

# 图片 CDN 服务商，可选 upyun、aliyun、tencent、cloudinary、imagekit、local。
VITE_IMAGE_CDN_PROVIDER="upyun"

# 图片 CDN 公开访问域名，不带结尾 /。本地开发可留空，留空时使用 /uploads。
VITE_IMAGE_CDN_BASE_URL=""

# 图片转换默认质量，建议 70-85。
VITE_IMAGE_CDN_QUALITY="75"

# AppImage 生成 srcset 时使用的响应式宽度列表。
VITE_IMAGE_CDN_WIDTHS="120,240,360,480,720,1080"
