{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "rootDir": ".",
    "outDir": "dist-server",
    "sourceMap": true,
    "noEmit": false
  },
  "include": ["server.ts", "src/server/**/*.ts"]
}
